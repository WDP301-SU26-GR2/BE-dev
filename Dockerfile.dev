# Image dành cho FE devs — chạy cả MongoDB lẫn NestJS trong 1 container.
# Không dùng cho production (production dùng Dockerfile).

FROM node:22-slim

# Cài MongoDB 7 vào image Node (Debian bookworm)
RUN apt-get update \
 && apt-get install -y --no-install-recommends gnupg curl ca-certificates openssl \
 && curl -fsSL https://www.mongodb.org/static/pgp/server-7.0.asc \
    | gpg --dearmor -o /usr/share/keyrings/mongodb-server-7.0.gpg \
 && echo "deb [ arch=amd64,arm64 signed-by=/usr/share/keyrings/mongodb-server-7.0.gpg ] \
    https://repo.mongodb.org/apt/debian bookworm/mongodb-org/7.0 main" \
    > /etc/apt/sources.list.d/mongodb-org-7.0.list \
 && apt-get update \
 && apt-get install -y --no-install-recommends mongodb-org redis-server \
 && rm -rf /var/lib/apt/lists/* \
 && corepack enable \
 && mkdir -p /data/db /var/log/mongodb /var/lib/redis

WORKDIR /app
