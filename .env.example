## App
PORT=PORT_example
SALT_OR_ROUNDS=SALT_OR_ROUNDS_example

## Database (đổi `mongo` thành `localhost` nếu chạy BE ngoài docker)
DATABASE_URL=MONGODB_URL_example
REDIS_URL=redis://localhost:6379

## JWT
ACCESS_TOKEN_SECRET=change_me_access_secret
REFRESH_TOKEN_SECRET=change_me_refresh_secret
ACCESS_TOKEN_EXPIRES_IN=1h
REFRESH_TOKEN_EXPIRES_IN=7d

## API
API_KEY=api_key_example
AUTH_TYPE_KEY=authType_example

## Seed admin
ADMIN_NAME=Admin Name Example
ADMIN_PASSWORD=Admin Password Example
ADMIN_EMAIL=Admin Email Example
ADMIN_PHONE=Admin Phone Example

## OTP
OTP_EXPIRES_IN=5m
