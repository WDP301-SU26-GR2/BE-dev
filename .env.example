PORT=
SALT_OR_ROUNDS=
NAME_APP=Mangaka
NODE_ENV=development
API_KEY=
AUTH_TYPE_KEY=

DATABASE_URL=mongodb://localhost:27017/Mangaka?replicaSet=rs0
REDIS_URL=redis://localhost:6379

ACCESS_TOKEN_SECRET=change-me-access
REFRESH_TOKEN_SECRET=change-me-refresh
ACCESS_TOKEN_EXPIRES_IN=
REFRESH_TOKEN_EXPIRES_IN=

ADMIN_NAME=
ADMIN_PASSWORD=
ADMIN_EMAIL=
ADMIN_PHONE=

OTP_EXPIRES_IN=5m
RESEND_API_KEY=
# Email sender ("Name <addr@domain>", domain must be Resend-verified) + logo URL (public deployed image; empty → text fallback)
EMAIL_FROM=
EMAIL_LOGO_URL=

# ======================
# GOOGLE OAUTH
# ======================
GOOGLE_CLIENT_ID=

# ======================
# R2 (Cloudflare R2 object storage, S3-compatible)
# ======================
# Account endpoint, e.g. https://<accountid>.r2.cloudflarestorage.com  (REQUIRED — no default)
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=mangaka-dev
R2_REGION=auto

OTP_RL_EMAIL_MAX=10
OTP_RL_EMAIL_WINDOW=3600
OTP_RL_IP_MAX=50
OTP_RL_IP_WINDOW=3600
OTP_RL_COOLDOWN=30
DEADLINE_WARN_THRESHOLD_HOURS=
DEADLINE_SLOT_GRACE_HOURS=
NAME_MAX_REVIEW_ROUNDS=8
ORPHAN_ASSET_TTL_HOURS=
TRUST_PROXY_HOPS=
# Comma-separated allowed HTTP/WebSocket origins; empty allows all origins.
CORS_ORIGINS=
# Guest identity/IP HMAC pepper (B-VOT-03). Strong random secret in prod; empty = dev-only, no leak-resistance.
IDENTITY_HASH_PEPPER=

# AI service (Spec 2) - empty AI_SERVICE_URL means AI disabled
AI_SERVICE_URL=
AI_SERVICE_API_KEY=
AI_HTTP_TIMEOUT_MS=120000
