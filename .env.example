PORT=4000
SALT_OR_ROUNDS=10
NAME_APP=Mangaka
NODE_ENV=development
API_KEY=WDP_MANGAKA
AUTH_TYPE_KEY=authType

DATABASE_URL=mongodb://localhost:27017/Mangaka?replicaSet=rs0
REDIS_URL=redis://localhost:6379

ACCESS_TOKEN_SECRET=change-me-access
REFRESH_TOKEN_SECRET=change-me-refresh
ACCESS_TOKEN_EXPIRES_IN=1h
REFRESH_TOKEN_EXPIRES_IN=7d

ADMIN_NAME=Admin
ADMIN_PASSWORD=admin@123123
ADMIN_EMAIL=admin@example.com
ADMIN_PHONE=0900000000

OTP_EXPIRES_IN=5m
RESEND_API_KEY=
# Email sender ("Name <addr@domain>", domain must be Resend-verified) + logo URL (public deployed image; empty → text fallback)
EMAIL_FROM=Mangaka <ecom@novaproj.site>
EMAIL_LOGO_URL=

# ======================
# GOOGLE OAUTH
# ======================
GOOGLE_CLIENT_ID=

# ======================
# R2
# ======================
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=mangaka-dev
R2_REGION=auto

OTP_RL_EMAIL_MAX=5
OTP_RL_EMAIL_WINDOW=3600
OTP_RL_IP_MAX=20
OTP_RL_IP_WINDOW=3600
OTP_RL_COOLDOWN=60
DEADLINE_WARN_THRESHOLD_HOURS=48
DEADLINE_SLOT_GRACE_HOURS=48
ORPHAN_ASSET_TTL_HOURS=24
TRUST_PROXY_HOPS=1
