# Spec/plan docs (superpowers) — root-level docs/ ONLY.
# Leading slash = anchored to repo root, so `src/core/http/docs/` (real source,
# ENUM_DOCS/ERROR_HINTS) is NOT matched and stays tracked. Do NOT change to `docs/`.
/docs

# temp directory
.temp
.tmp
.worktrees

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Diagnostic reports (https://nodejs.org/api/report.html)
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json

/generated/prisma

# pnpm local store (xuất hiện khi pnpm config store-dir trỏ vào project)
.pnpm-store

# Local smoke/dev scripts (ephemeral; excluded from prod build too — see tsconfig.build.json).
# The directory is ignored by default; only planned tracked JS scripts are excepted.
!/scripts/
/scripts/*
!/scripts/migrate-notification-dedupe.mjs
!/scripts/smoke-spec13.mjs

