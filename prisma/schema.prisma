generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "mongodb"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL")
}

model User {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  email       String  @unique
  name        String
  displayName String?
  password    String
  phoneNumber String
  avatar      String?
  googleId    String?

  roleId String @db.ObjectId

  status UserStatus @default(INACTIVE)

  emailVerified Boolean @default(false)

  registrationType RegistrationType @default(SELF_REGISTERED)

  mustChangePassword Boolean @default(false)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  role          Role           @relation(fields: [roleId], references: [id])
  refreshTokens RefreshToken[]

  mangakaProfile   MangakaProfile?
  assistantProfile AssistantProfile?
  staffProfile     StaffProfile?
  mangakaContracts Contract[]        @relation("MangakaRelation")
  editorContracts  Contract[]        @relation("EditorRelation")
  boardSessions    BoardSession[]

  receivedPayments PaymentRecord[] @relation("PaymentReceiver")

  @@index([deletedAt])
}

model RefreshToken {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  token String @unique

  userId String @db.ObjectId
  user   User   @relation(fields: [userId], references: [id])

  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model Role {
  id          String  @id @default(auto()) @map("_id") @db.ObjectId
  code        String  @unique
  description String?
  isSystem    Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users User[]
}

model OtpRequest {
  id          String     @id @default(auto()) @map("_id") @db.ObjectId
  email       String // email
  otpCodeHash String
  ip          String?
  purpose     OtpPurpose

  createdAt DateTime @default(now())
  expiresAt DateTime
  attempts  Int      @default(0)
  isUsed    Boolean  @default(false)

  @@unique([email, purpose])
  @@index([expiresAt])
}

enum OtpPurpose {
  REGISTER
  FORGOT_PASSWORD
  SIGNING_CONTRACT
  VOTE
}

enum UserStatus {
  INACTIVE
  ACTIVE
  BANNED
  BLOCKED
}

