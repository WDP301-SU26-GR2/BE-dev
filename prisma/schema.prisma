model AuditLog {
  id         String          @id @default(auto()) @map("_id") @db.ObjectId
  actorId    String?         @db.ObjectId
  entityType AuditEntityType
  entityId   String          @db.ObjectId
  action     String
  fromState  String?
  toState    String?
  reason     String?
  createdAt  DateTime        @default(now())

