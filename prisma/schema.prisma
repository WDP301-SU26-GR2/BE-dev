model BoardSession {
  id               String             @id @default(auto()) @map("_id") @db.ObjectId
  title            String
  description      String?
  creatorId        String             @db.ObjectId
  creator          User               @relation(fields: [creatorId], references: [id])
  status           BoardSessionStatus @default(UPCOMING)
  phase            BoardSessionPhase  @default(PRESENTING) // Spec 16: creator điều khiển, forward-only
  allowedEditorIds String[]           @db.ObjectId // Danh sách sếp được mời họp tổng
  startTime        DateTime
  endTime          DateTime? // Fix-2 G-7: auto-conclude when ACTIVE session passes this time; null = manual-only conclude
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  decisions BoardDecision[]
}

// Spec 16: tin nhắn Q&A trong phiên họp Board — persist để rejoin thấy lịch sử.
model BoardMessage {
  id        String            @id @default(auto()) @map("_id") @db.ObjectId
  sessionId String            @db.ObjectId
  senderId  String            @db.ObjectId
  content   String
  phase     BoardSessionPhase // snapshot phase lúc gửi
  createdAt DateTime          @default(now())

  @@index([sessionId])
}

