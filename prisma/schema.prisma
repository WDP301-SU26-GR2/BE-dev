generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "mongodb"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL")
}

model User {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  email       String  @unique
  name        String
  displayName String?
  password    String
  phoneNumber String
  avatar      String?

  roleId String @db.ObjectId

  status UserStatus @default(INACTIVE)

  emailVerified Boolean @default(false)

  registrationType RegistrationType @default(SELF_REGISTERED)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  role          Role           @relation(fields: [roleId], references: [id])
  refreshTokens RefreshToken[]

  mangakaProfile   MangakaProfile?
  assistantProfile AssistantProfile?

  @@index([deletedAt])
}

model RefreshToken {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  token String @unique

  userId String @db.ObjectId
  user   User   @relation(fields: [userId], references: [id])

  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model Role {
  id          String  @id @default(auto()) @map("_id") @db.ObjectId
  code        String  @unique
  description String?
  isSystem    Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users User[]
}

model OtpRequest {
  id          String     @id @default(auto()) @map("_id") @db.ObjectId
  email       String // email
  otpCodeHash String
  ip          String?
  purpose     OtpPurpose

  createdAt DateTime @default(now())
  expiresAt DateTime
  attempts  Int      @default(3)
  isUsed    Boolean  @default(false)

  @@unique([email, purpose, otpCodeHash])
  @@index([expiresAt])
}

enum OtpPurpose {
  REGISTER
  FORGOT_PASSWORD
  SIGNING_CONTRACT
}

enum UserStatus {
  INACTIVE
  ACTIVE
  BANNED
  BLOCKED
}

// ===== Enums from ERD §3 catalog (exact) =====

enum RegistrationType {
  SELF_REGISTERED
  ADMIN_CREATED
}

enum RoleCode {
  MANGAKA
  ASSISTANT
  EDITOR
  BOARD_MEMBER
  SUPER_ADMIN
}

enum PublicationType {
  WEEKLY
  MONTHLY
  IRREGULAR
}

enum RelationshipType {
  SEQUEL
  SPINOFF
  SIDE_STORY
  REBOOT
}

enum ContractType {
  FULL_BUYOUT
  REVENUE_SHARE
}

enum ContractStatus {
  DRAFT
  MANGAKA_REVIEW
  MANGAKA_APPROVED
  BOARD_APPROVED
  NEGOTIATION
  MANGAKA_SIGNED
  FULLY_EXECUTED
  FULFILLED
  TERMINATED
  TERMINATED_BY_BREACH
  EXPIRED
  VOIDED
}

enum ConditionType {
  CHAPTER_MILESTONE
  RECURRING_CHAPTER
  RANKING_MILESTONE
  TIME_BOUND
}

enum PaymentType {
  CONDITION_PAYOUT
  REVENUE_SHARE
  COMPENSATION
}

enum ReprintRevisionMode {
  AS_IS
  WITH_REVISION
}

enum TransferType {
  FULL_TRANSFER
  PARTIAL_TRANSFER
}

enum AvailabilityStatus {
  AVAILABLE
  BUSY
  ON_LEAVE
  UNAVAILABLE
}

enum Specialization {
  BACKGROUND
  SCREENTONE
  EFFECT_LINES
  INKING
  COLORING
  LETTERING
}

enum TaskStatus {
  ASSIGNED
  IN_PROGRESS
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  REVISION_REQUESTED
  ON_HOLD
}

enum ManuscriptStatus {
  DRAFT
  IN_PRODUCTION
  COMPOSITE_REVIEW
  EDITOR_REVIEW
  EDITOR_REVISION
  READY_FOR_PRINT
  AWAITING_CO_OWNER_APPROVAL
  PUBLISHED
}

enum DeadlineRequestStatus {
  PROPOSED
  COUNTER_PROPOSED
  AGREED_BY_PARTIES
  BOARD_REVIEW
  ESCALATED
  APPROVED
  REJECTED
}

