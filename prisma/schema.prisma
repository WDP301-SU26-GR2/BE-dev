enum NameStatus {
  DRAFT
  SUBMITTED
  IN_REVIEW
  REVISION
  APPROVED
}

// REVIEW: inferred
enum ChapterStatus {
  DRAFT
  IN_PRODUCTION
  COMPLETED
  PUBLISHED
}

// REVIEW: inferred
