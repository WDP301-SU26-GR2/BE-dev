model MangakaProfile {
  id     String @id @default(auto()) @map("_id") @db.ObjectId
  userId String @unique @db.ObjectId
  user   User   @relation(fields: [userId], references: [id])

  penName         String
  genres          Genre[]
  experienceLevel String?
  bio             String?
  portfolioFiles  String[]

  reputationScore Float   @default(0)
  ratingAvg       Float   @default(0)
  ratingCount     Int     @default(0)
  isRecommended   Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AssistantProfile {
  id     String @id @default(auto()) @map("_id") @db.ObjectId
  userId String @unique @db.ObjectId
  user   User   @relation(fields: [userId], references: [id])

  specializations    Specialization[]
  experienceLevel    String?
  portfolioFiles     String[]
  availabilityStatus AvailabilityStatus @default(AVAILABLE)
  availabilityFrom   DateTime?
  availabilityTo     DateTime?

  reputationScore Float   @default(0)
  ratingAvg       Float   @default(0)
  ratingCount     Int     @default(0)
  isRecommended   Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Spec 12 — Profile & Identity Completion: hồ sơ nhân sự NXB (EDITOR + BOARD_MEMBER)
model StaffProfile {
  id     String @id @default(auto()) @map("_id") @db.ObjectId
  userId String @unique @db.ObjectId
  user   User   @relation(fields: [userId], references: [id])

  specialtyGenres   Genre[]
  demographics      Demographic[]
  bio               String?
  yearsOfExperience Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// REVIEW: inferred
enum TaskVersionReviewStatus {
  PENDING
  APPROVED
  REVISION_REQUESTED
}

enum AiJobType {
  SEGMENT
  COLOR
  NUMBER
}

enum AiJobStatus {
  QUEUED
  RUNNING
  SUCCEEDED
  FAILED
}

enum AiSegmentMode {
  MODEL
  HEURISTIC
}

enum BoardSessionStatus {
  UPCOMING
  ACTIVE
  CONCLUDED
}

// Spec 16: giai đoạn trong phiên họp Board (Requiment Flow 1: trình bày → Q&A → vote)
enum BoardSessionPhase {
  PRESENTING
  QA
  VOTING
}

enum BoardDecisionResult {
  PENDING
  PENDING_QUORUM
  APPROVED
  REJECTED
  EXPIRED
}

enum VoteValue {
  APPROVE
  REJECT
  ABSTAIN
}

model Series {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  mangakaId String  @db.ObjectId
  editorId  String? @db.ObjectId
  coOwnerId String? @db.ObjectId

  parentSeriesId String?  @db.ObjectId
  parentSeries   Series?  @relation("SeriesLineage", fields: [parentSeriesId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  childSeries    Series[] @relation("SeriesLineage")

  title                   String
  coverImage              String?
  genres                  Genre[]
  demographic             Demographic?
  publicationType         PublicationType?
  status                  SeriesStatus               @default(DRAFT)
  statusReason            String?
  relationshipType        RelationshipType?
  // Spec 3 / A-SER-06: gate đồng ý franchise. null = không gate; PENDING khi parent REVENUE_SHARE
  // (FULLY_EXECUTED) & khác mangaka; APPROVED/REJECTED do Mangaka gốc quyết.
  franchiseConsentStatus FranchiseConsentStatus?
  magazine                String? // Flow 1 slot: tạp chí Board chọn khi serial hoá (null tới khi SERIALIZED — set bởi A1)
  startIssueNumber        Int? // Flow 1 slot: số kỳ (issue) series bắt đầu đăng (null tới khi SERIALIZED — set bởi A1)
  coOwnerApprovalRequired Boolean                    @default(false)
  reviewStartedAt         DateTime?
  hiatusStartedAt         DateTime? // Spec 2: set when entering HIATUS, null when resumed — used to compute pausedMs
  endingChapterAllowance  Int? // Spec 2 + Fix-1: N ending chapters Board grants on CANCELLATION — ENFORCED bởi chapter-creation guard
  chapterCountAtCancelling Int? // Fix-1 G-1: snapshot số chapter tại thời điểm vào CANCELLING — guard ending allowance
  completionProposal      CompletionProposal?
  statusHistory           SeriesStatusHistoryEntry[]

  proposal SeriesProposal?

  names               Name[]
  publicationVersions PublicationVersion[]
  chapters            Chapter[]

  createdAt DateTime   @default(now())
  contracts Contract[]

  @@index([mangakaId])
  @@index([editorId])
  @@index([coOwnerId])
  @@index([parentSeriesId])
}

type SeriesProposal {
  nameId           String?        @db.ObjectId
  synopsis         String?
  characterDesigns String[]
  estimatedLength  Int?
  status           ProposalStatus @default(DRAFT)
  createdAt        DateTime       @default(now())
}

type CompletionProposal {
  proposedByRole         String
  proposedById          String   @db.ObjectId
  reason                String
  proposedEndingChapters Int?
  proposedAt             DateTime
}

type SeriesStatusHistoryEntry {
  fromStatus String
  toStatus   String
  changedBy  String?  @db.ObjectId
  reason     String?
  at         DateTime
}

model Name {
  id       String @id @default(auto()) @map("_id") @db.ObjectId
  seriesId String @db.ObjectId
  series   Series @relation(fields: [seriesId], references: [id])

  chapterId String?  @db.ObjectId
  chapter   Chapter? @relation(fields: [chapterId], references: [id])

  chapterNumber Int?
  status        NameStatus @default(DRAFT)
  kind          NameKind   @default(PROPOSAL)
  version       Int        @default(1)
  submittedAt   DateTime?

  pages NamePage[]

  @@index([seriesId])
  @@index([chapterId])
}

type NamePage {
  pageNumber Int
  fileUrl    String
}

model PublicationVersion {
  id       String @id @default(auto()) @map("_id") @db.ObjectId
  seriesId String @db.ObjectId
  series   Series @relation(fields: [seriesId], references: [id])

  language         String
  readingDirection ReadingDirection @default(RTL)
  versionType      String?
  notes            String?
  createdAt        DateTime         @default(now())

  @@index([seriesId])
}

model Chapter {
  id       String @id @default(auto()) @map("_id") @db.ObjectId
  seriesId String @db.ObjectId
  series   Series @relation(fields: [seriesId], references: [id])

  nameId String? @db.ObjectId

  chapterNumber Int
  title         String?
  totalPages    Int?
  status        ChapterStatus      @default(DRAFT)
  publishedAt   DateTime?
  hold          ChapterHold?
  holdHistory   ChapterHoldEntry[]

  schedule        Schedule?
  manuscript      Manuscript?
  pages           Page[]
  boardDecision   BoardDecision? @relation(fields: [boardDecisionId], references: [id])
  boardDecisionId String?        @db.ObjectId

  names Name[]

  @@index([seriesId])
  @@index([nameId])
}

model ChapterCoOwnerApproval {
  id        String @id @default(auto()) @map("_id") @db.ObjectId
  chapterId String @db.ObjectId

  status        CoOwnerApprovalStatus @default(PENDING)
  coOwnerId     String?               @db.ObjectId
  decisionAt    DateTime?
  rejectReason  String?
  deadline      DateTime?
  escalatedAt   DateTime?
  escalatedToId String?               @db.ObjectId
  escalatedTo   BoardDecision?        @relation(fields: [escalatedToId], references: [id])

  createdAt DateTime @default(now())

  @@index([chapterId])
  @@index([escalatedToId])
}

enum CoOwnerApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  ESCALATED
}

model Schedule {
  id        String  @id @default(auto()) @map("_id") @db.ObjectId
  chapterId String  @unique @db.ObjectId
  chapter   Chapter @relation(fields: [chapterId], references: [id])

  originalDeadline DateTime?
  currentDeadline  DateTime?
  extended         Boolean   @default(false)

  extensions       ScheduleExtension[]
  deadlineRequests DeadlineRequest[]
}

type ScheduleExtension {
  extendedBy       String?   @db.ObjectId
  previousDeadline DateTime?
  newDeadline      DateTime?
  reason           String?
  extendedAt       DateTime  @default(now())
}

type DeadlineRequestStatusHistoryEntry {
  from   DeadlineRequestStatus?
  to     DeadlineRequestStatus
  by     String?                @db.ObjectId
  reason String?
  at     DateTime               @default(now())
}

model DeadlineRequest {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  scheduleId String   @db.ObjectId
  schedule   Schedule @relation(fields: [scheduleId], references: [id])

  chapterId       String? @db.ObjectId
  seriesId        String? @db.ObjectId
  boardReviewedBy String? @db.ObjectId

  requestedBy       String?
  currentDeadline   DateTime?
  requestedDeadline DateTime?
  reason            String?
  affectsSlot       Boolean                             @default(false)
  status            DeadlineRequestStatus               @default(PROPOSED)
  resolvedAt        DateTime?
  createdAt         DateTime                            @default(now())
  lastProposedBy    String?
  statusHistory     DeadlineRequestStatusHistoryEntry[]

  @@index([scheduleId])
  @@index([chapterId])
  @@index([seriesId])
}

// A3: Thêm embedded type cho audit transition production (mirror SeriesStatusHistoryEntry)
type ManuscriptStatusHistoryEntry {
  from      ManuscriptStatus?
  to        ManuscriptStatus
  changedBy String?           @db.ObjectId
  reason    String?
  changedAt DateTime          @default(now())
}

model Manuscript {
  id        String  @id @default(auto()) @map("_id") @db.ObjectId
  chapterId String  @unique @db.ObjectId
  chapter   Chapter @relation(fields: [chapterId], references: [id])

  status              ManuscriptStatus               @default(DRAFT)
  finalFile           String?
  submittedToEditorAt DateTime?
  approvedAt          DateTime?
  statusHistory       ManuscriptStatusHistoryEntry[]
}

model Page {
  id        String  @id @default(auto()) @map("_id") @db.ObjectId
  chapterId String  @db.ObjectId
  chapter   Chapter @relation(fields: [chapterId], references: [id])

  pageNumber    Int
  originalFile  String?
  compositeFile String?
  status        PageStatus @default(DRAFT)
  createdAt     DateTime   @default(now())

  regions Region[]
  tasks   Task[]

  @@index([chapterId])
}

model Region {
  id     String @id @default(auto()) @map("_id") @db.ObjectId
  pageId String @db.ObjectId
  page   Page   @relation(fields: [pageId], references: [id])

  coordinates        Json?
  regionType         RegionType?
  detectedSubtype    String?
  createdBy          String?
  confirmedByMangaka Boolean     @default(false)
  confidenceScore    Float?
  aiModelVersion     String?

  @@index([pageId])
}

model Task {
  id          String  @id @default(auto()) @map("_id") @db.ObjectId
  pageId      String  @db.ObjectId
  page        Page    @relation(fields: [pageId], references: [id])
  regionId    String? @db.ObjectId
  assistantId String? @db.ObjectId

  taskType     Specialization?
  status       TaskStatus      @default(ASSIGNED)
  priority     Int             @default(0)
  deadline     DateTime?
  createdAt    DateTime        @default(now())
  assetIds     String[]        @default([]) @db.ObjectId
  statusReason String?

  versions    TaskVersion[]
  annotations Annotation[]

  @@index([pageId])
  @@index([regionId])
  @@index([assistantId])
}

model AiJob {
  id          String         @id @default(auto()) @map("_id") @db.ObjectId
  type        AiJobType
  mode        AiSegmentMode?
  pageId      String         @db.ObjectId
  requestedBy String         @db.ObjectId

  status          AiJobStatus @default(QUEUED)
  error           String?
  modelVersion    String?
  proposedRegions Json?
  regionCount     Int?
  appliedAt       DateTime?
  startedAt       DateTime?
  finishedAt      DateTime?
  durationMs      Int?
  createdAt       DateTime    @default(now())

  @@index([pageId, type, status])
  @@index([requestedBy])
}

type TaskVersion {
  submittedBy   String?                 @db.ObjectId
  versionNumber Int
  file          String?
  reviewStatus  TaskVersionReviewStatus @default(PENDING)
  reviewerNote  String?
  submittedAt   DateTime                @default(now())
}

// REVIEW: inferred — A3 reconcile: taskId optional (Editor annotate Manuscript/Page không có Task)
model Annotation {
  id     String  @id @default(auto()) @map("_id") @db.ObjectId
  taskId String? @db.ObjectId
  task   Task?   @relation(fields: [taskId], references: [id])

  authorId String? @db.ObjectId

  targetType     AnnotationTargetType?
  targetId       String?               @db.ObjectId
  coordinates    Json?
  reviewStage    ReviewStage?
  authorRole     String?
  annotationType AnnotationType?
  content        String?
  isResolved     Boolean               @default(false)
  resolvedAt     DateTime?
  createdAt      DateTime              @default(now())

  @@index([taskId])
  @@index([authorId])
}

model Asset {
  id         String  @id @default(auto()) @map("_id") @db.ObjectId
  uploadedBy String? @db.ObjectId

  name       String
  filePath   String
  assetType  AssetType?
  uploadedAt DateTime   @default(now())

  @@index([uploadedBy])
}

model CollaborationInvite {
  id          String  @id @default(auto()) @map("_id") @db.ObjectId
  mangakaId   String  @db.ObjectId
  assistantId String  @db.ObjectId
  seriesId    String? @db.ObjectId

  hireStart DateTime?
  hireEnd   DateTime?
  taskTypes Specialization[]
  status    CollaborationInviteStatus @default(PENDING)
  createdAt DateTime                  @default(now())

  @@index([mangakaId])
  @@index([assistantId])
  @@index([seriesId])
}

model StudioAssignment {
  id          String  @id @default(auto()) @map("_id") @db.ObjectId
  mangakaId   String  @db.ObjectId
  assistantId String  @db.ObjectId
  seriesId    String? @db.ObjectId

  hireStart         DateTime?
  hireEnd           DateTime?
  assignedTaskTypes Specialization[]
  status            StudioAssignmentStatus @default(ACTIVE)
  terminatedReason  String?
  createdAt         DateTime               @default(now())

  @@index([mangakaId])
  @@index([assistantId])
  @@index([seriesId])
}

model AssistantReview {
  id                 String  @id @default(auto()) @map("_id") @db.ObjectId
  studioAssignmentId String? @db.ObjectId
  mangakaId          String  @db.ObjectId
  assistantId        String  @db.ObjectId
  seriesId           String? @db.ObjectId

  rating    Int
  comment   String?
  createdAt DateTime @default(now())

  @@unique([mangakaId, assistantId])
  @@index([studioAssignmentId])
  @@index([mangakaId])
  @@index([assistantId])
  @@index([seriesId])
}

model MangakaReview {
  id        String  @id @default(auto()) @map("_id") @db.ObjectId
  seriesId  String? @db.ObjectId
  editorId  String  @db.ObjectId
  mangakaId String  @db.ObjectId

  rating    Int
  comment   String?
  createdAt DateTime @default(now())

  @@unique([editorId, mangakaId])
  @@index([seriesId])
  @@index([editorId])
  @@index([mangakaId])
}

model Contract {
  id              String         @id @default(auto()) @map("_id") @db.ObjectId
  seriesId        String         @db.ObjectId
  series          Series         @relation(fields: [seriesId], references: [id])
  mangakaId       String         @db.ObjectId
  mangaka         User           @relation("MangakaRelation", fields: [mangakaId], references: [id])
  editorId        String?        @db.ObjectId
  editor          User?          @relation("EditorRelation", fields: [editorId], references: [id])
  boardDecisionId String?        @db.ObjectId
  boardDecision   BoardDecision? @relation(fields: [boardDecisionId], references: [id])

  sourceTransferRequestId String? @db.ObjectId

  contractType          ContractType
  valuationAmount       Float?
  publisherOwnershipPct Float?
  mangakaOwnershipPct   Float?
  terminationClause     String?
  contractStart         DateTime?
  contractEnd           DateTime?
  status                ContractStatus @default(DRAFT)
  mangakaSignedAt       DateTime?
  boardSignedAt         DateTime?
  // Internal serialization fence: every signing transaction writes a fresh token so concurrent
  // signers contend on the same Contract document and the loser retries from a fresh snapshot.
  signingFence          String?
  createdAt             DateTime       @default(now())

  conditions         PaymentCondition[]
  payments           PaymentRecord[]
  amendments         ContractAmendment[]
  versions           ContractVersion[]
  contractSignatures ContractSignature[]
  originOfTransfers  TransferRequest[]   @relation("OriginalContractOfTransfer")

  @@index([seriesId])
  @@index([mangakaId])
  @@index([editorId])
  @@index([boardDecisionId])
  @@index([sourceTransferRequestId])
}

model ContractVersion {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  contractId String   @db.ObjectId
  contract   Contract @relation(fields: [contractId], references: [id])

  versionNumber         Int
  valuationAmount       Float?
  publisherOwnershipPct Float?
  mangakaOwnershipPct   Float?
  terminationClause     String?
  editedById            String   @db.ObjectId
  note                  String?
  createdAt             DateTime

  // S-05 (BACKEND_AUDIT_2026-07-20): versionNumber được cấp bằng `versions.length + 1` đọc từ
  // snapshot NGOÀI transaction (contract.service + contract-amendment.repo) → hai lần sửa/phụ lục
  // đồng thời cấp trùng số. Unique ép người thua nhận P2002 để retry lấy số kế tiếp.
  @@unique([contractId, versionNumber])
  @@index([contractId])
  @@index([editedById])
}

model ContractSignature {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  contractId String   @db.ObjectId
  userId     String   @db.ObjectId
  role       String
  signedAt   DateTime @default(now())

  contract Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@unique([contractId, userId])
}

model PaymentCondition {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  contractId String   @db.ObjectId
  contract   Contract @relation(fields: [contractId], references: [id])

  conditionType      ConditionType
  thresholdConfig    Json?
  payoutAmount       Float?
  payoutPct          Float?
  isRecurring        Boolean                @default(false)
  status             PaymentConditionStatus @default(PENDING)
  lastTriggeredValue Int?                   @default(0)
  achievedAt         DateTime?

  payments PaymentRecord[]

  @@index([contractId])
}

model PaymentRecord {
  id          String            @id @default(auto()) @map("_id") @db.ObjectId
  contractId  String            @db.ObjectId
  contract    Contract          @relation(fields: [contractId], references: [id])
  conditionId String?           @db.ObjectId
  condition   PaymentCondition? @relation(fields: [conditionId], references: [id])

  receiverId String @db.ObjectId
  receiver   User   @relation("PaymentReceiver", fields: [receiverId], references: [id])

  seriesId String? @db.ObjectId

  description   String?
  approvedBy    String?       @db.ObjectId
  approvedAt    DateTime?
  paymentType   PaymentType
  paymentSource PaymentSource @default(CONTRACT)
  amount        Float
  period        String?

  paymentMethod        String?
  transactionReference String?
  status               PaymentRecordStatus @default(PENDING)
  paidAt               DateTime?

  cancelledAt  DateTime?
  cancelReason String?

  note String?

  createdBy String?  @db.ObjectId
  createdAt DateTime @default(now())

  // S-03 (BACKEND_AUDIT_2026-07-20): khoá idempotency ở tầng DB. `existsPayment` chỉ là
  // lớp lọc rẻ và KHÔNG nguyên tử — hai event/retry đồng thời đều thấy "chưa tồn tại" rồi
  // cùng ghi. Unique index này là nguồn sự thật: request thua nhận P2002 và bị
  // `createPaymentOnce` nuốt thành "đã tồn tại".
  // ⚠ Mọi field trong khoá phải được ghi null TƯỜNG MINH (xem payment.repo.createTriggeredPayment):
  // Mongo index coi field absent như null, nhưng Prisma `where: { x: null }` KHÔNG match doc absent.
  // Tuple an toàn vì `period` luôn có giá trị: `chapter:N` · `survey:<id>` · `termination:<seriesId>`
  // · kỳ doanh thu — nên các mốc recurring/nhiều người nhận không đụng nhau.
  @@unique([contractId, conditionId, receiverId, paymentType, period], name: "payment_idempotency")
  @@index([contractId])
  @@index([conditionId])
  @@index([approvedBy])
  @@index([receiverId])
  @@index([seriesId])
  @@index([status])
  @@index([paymentType])
  @@index([paymentSource])
}

model ContractAmendment {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  contractId String   @db.ObjectId
  contract   Contract @relation(fields: [contractId], references: [id])

  changedClauses  String[]
  reason          String?
  status          ContractAmendmentStatus @default(DRAFT)
  fullyExecutedAt DateTime?
  createdAt       DateTime                @default(now())

  // Spec 4 — typed new-term (null = KHÔNG đổi field đó)
  valuationAmount       Float?
  publisherOwnershipPct Float?
  mangakaOwnershipPct   Float?
  terminationClause     String?
  contractStart         DateTime?
  contractEnd           DateTime?

  // Spec 4 — signing progress
  mangakaSignedAt DateTime?
  boardSignedAt   DateTime?

  // Spec 4 — audit
  createdBy     String?          @db.ObjectId
  triggerSource AmendmentTrigger @default(MANUAL)
  voidReason    String?

  signatures AmendmentSignature[]

  @@index([contractId])
}

model AmendmentSignature {
  id          String            @id @default(auto()) @map("_id") @db.ObjectId
  amendmentId String            @db.ObjectId
  amendment   ContractAmendment @relation(fields: [amendmentId], references: [id], onDelete: Cascade)
  userId      String            @db.ObjectId
  role        String
  signedAt    DateTime          @default(now())

  @@unique([amendmentId, userId])
}

model ReprintRequest {
