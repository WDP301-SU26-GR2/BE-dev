  DRAFT
  IN_REVIEW
  READY_TO_PITCH
  PITCHED
  SERIALIZED
  HIATUS
  COMPLETING
  CANCELLING
  COMPLETED
  CANCELLED
  REJECTED
  ABANDONED
  WITHDRAWN
}

// REVIEW: inferred
