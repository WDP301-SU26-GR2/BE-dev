  report                  SeriesReport?
  contracts               Contract[]
  transferRequests        TransferRequest[]
  escalatedChapters       Chapter[]
  chapterCoOwnerApprovals ChapterCoOwnerApproval[]

  @@index([targetSeriesId])
}

