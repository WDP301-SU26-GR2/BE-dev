model TransferContractSignature {
  id                 String           @id @default(auto()) @map("_id") @db.ObjectId
  transferContractId String           @db.ObjectId
  transferContract   TransferContract @relation(fields: [transferContractId], references: [id], onDelete: Cascade)

  userId   String   @db.ObjectId
