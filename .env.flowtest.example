# FLOW-TEST env — copy thành `.env.flowtest` (gitignored) rồi điền secret như `.env` dev.
# BẮT BUỘC: DATABASE_URL phải chứa 'flowtest' (lib/env.ts guard chống wipe nhầm DB dev).
# AI_SERVICE_URL để TRỐNG (flow-03 test nhánh AI-tắt 503).
# PORT đổi 4100 để không đụng dev server :4000.

PORT=4100
SALT_OR_ROUNDS=10
NAME_APP=
NODE_ENV=
API_KEY=""
AUTH_TYPE_KEY=""

#Database
DATABASE_URL="mongodb://localhost:27017/Mangaka-flowtest?replicaSet=rs0"
# Redis DB index RIÊNG (5) cho flowtest — cô lập BullMQ queue + cron lock khỏi dev server cùng máy.
REDIS_URL=redis://localhost:6379/5

###JWT
ACCESS_TOKEN_SECRET=
ACCESS_TOKEN_EXPIRES_IN=
REFRESH_TOKEN_EXPIRES_IN=

###key api
API_KEY=
AUTH_TYPE_KEY=

###Seed Data
#Admin
ADMIN_NAME=
ADMIN_PASSWORD=
ADMIN_EMAIL=
ADMIN_PHONE=

# ======================
# OTP
# ======================
OTP_EXPIRES_IN=

# ======================
# RESEND API
# ======================
RESEND_API_KEY=
EMAIL_FROM=
EMAIL_LOGO_URL=

# ======================
# GOOGLE OAUTH
# ======================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=
GOOGLE_CLIENT_REDIRECT_URL=
GOOGLE_OAUTH_SCOPES_1=
GOOGLE_OAUTH_SCOPES_2=

# ======================
# R2
# ======================
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_REGION=

##
OTP_RL_EMAIL_MAX=
OTP_RL_EMAIL_WINDOW=
OTP_RL_IP_MAX=
OTP_RL_IP_WINDOW=
OTP_RL_COOLDOWN=
DEADLINE_WARN_THRESHOLD_HOURS=
DEADLINE_SLOT_GRACE_HOURS=
ORPHAN_ASSET_TTL_HOURS=
TRUST_PROXY_HOPS=

# AI service (Spec 2 - flowtest: TẮT để test nhánh 503 fallback manual)
# BỎ trống AI_SERVICE_URL = AI tắt
AI_SERVICE_URL=
AI_SERVICE_API_KEY=
AI_HTTP_TIMEOUT_MS=120000

# Guest identity/IP HMAC pepper (B-VOT-03)
IDENTITY_HASH_PEPPER=